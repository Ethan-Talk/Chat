{
  "compilerOptions": {
    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"] //@/로 시작하는 모든 경로는 src/로 연결됨
    },
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "sourceMap": true
  },
  "include": ["src"]
}
